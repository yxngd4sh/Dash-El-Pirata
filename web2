<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Dash El Pirata</title>

<link href="https://fonts.googleapis.com/css2?family=Inter&family=Oswald&display=swap" rel="stylesheet">

<style>
body {
  margin: 0;
  background: #0A0A0A;
  color: white;
  font-family: 'Inter', sans-serif;
}

/* HERO */
.hero {
  height: 100vh;
  background: linear-gradient(rgba(0,0,0,0.6), rgba(0,0,0,0.9)),
              url('./dash.jpg') center/cover no-repeat;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
}

.hero h1 {
  font-family: 'Oswald', sans-serif;
  font-size: 3rem;
  text-align: center;
}

.btn {
  margin-top: 20px;
  padding: 15px 30px;
  border-radius: 30px;
  background: #D4AF37;
  color: black;
  text-decoration: none;
}

/* LINKS */
.links {
  padding: 40px 20px;
}

.links a {
  display: block;
  margin: 10px auto;
  width: 80%;
  padding: 15px;
  border: 1px solid #D4AF37;
  border-radius: 30px;
  color: white;
  text-decoration: none;
}

/* RELEASE */
.release {
  text-align: center;
  padding: 40px;
}

.release img {
  width: 200px;
  border-radius: 10px;
}
</style>
</head>

<body>

<section class="hero">
  <h1>DASH EL PIRATA</h1>
  <p>Navegando el nuevo sonido</p>
  <a href="#" class="btn">Escuchar ahora</a>
</section>

<section class="links">
  <a href="#">Spotify</a>
  <a href="#">YouTube</a>
  <a href="#">Apple Music</a>
</section>

<section class="release">
  <img src="./cover.jpg" alt="cover">
  <h2>Último lanzamiento</h2>
  <a href="#" class="btn">Play</a>
</section>

</body>
</html>
